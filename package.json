    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "lucide-vue-next": "^1.0.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "vue": "^3.5.35",
    "vue-demi": "^0.14.10"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
